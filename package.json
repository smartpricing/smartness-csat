{
  "name": "smartness-csat",
  "version": "1.6.0",
  "description": "Smartness CSAT Feedback Service",
  "main": "index.js",
  "scripts": {
    "dev": "tsc && node --env-file-if-exists=.env dist/index.js",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "build": "tsc -p tsconfig.json",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:unit:coverage": "vitest run --coverage --config vitest.unit.config.ts",
    "test:integration:coverage": "vitest run --coverage --config vitest.integration.config.ts",
    "import:legacy": "tsc && node --env-file-if-exists=.env dist/scripts/import-legacy-data.js"
  },
  "type": "module",
  "keywords": [
    "smartness",
    "csat",
    "feedback"
  ],
  "author": "Smartness",
  "devDependencies": {
    "@biomejs/biome": "2.3.5",
    "@testcontainers/postgresql": "^11.8.1",
    "@tsconfig/node22": "^22.0.3",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "4.0.8",
    "dotenv": "^17.2.3",
    "msw": "^2.7.5",
    "supertest": "^7.1.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "@fastify/otel": "^0.13.1",
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.208.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.208.0",
    "@opentelemetry/instrumentation-http": "^0.208.0",
    "@opentelemetry/instrumentation-pg": "^0.61.0",
    "@opentelemetry/instrumentation-pino": "^0.55.0",
    "@opentelemetry/instrumentation-runtime-node": "^0.22.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-metrics": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.208.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "@scalar/fastify-api-reference": "^1.39.3",
    "axios": "^1.13.6",
    "date-fns": "^4.1.0",
    "fastify": "^5.6.2",
    "fastify-type-provider-zod": "^6.1.0",
    "pg": "^8.16.3",
    "zod": "^4.1.12"
  },
  "peerDependencies": {
    "pino": "^10.1.0"
  }
}
